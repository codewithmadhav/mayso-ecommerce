# ============================================
# MAYSO E-COMMERCE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# DJANGO SETTINGS
# ============================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mayso_ecommerce
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DB_CHARSET=utf8

# ============================================
# RAZORPAY CONFIGURATION (TEST MODE)
# ============================================
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mayso.com

# ============================================
# CORS SETTINGS
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8100,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ============================================
# AWS S3 (Optional - for production)
# ============================================
# USE_S3=False
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=mayso-ecommerce
# AWS_S3_REGION_NAME=us-east-1

# ============================================
# REDIS CONFIGURATION (For Celery)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# API KEYS
# ============================================
SMTP_PASSWORD=your-password
FLUTTER_API_KEY=your-flutter-api-key

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=development
TIMEZONE=Asia/Kolkata
LANGUAGE_CODE=en-us
